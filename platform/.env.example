# Janovum Platform — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Anthropic API key (required for Claude-powered features)
ANTHROPIC_API_KEY=

# Telegram bot token (optional — for Telegram integration)
TELEGRAM_BOT_TOKEN=

# Server port (default: 5050)
SERVER_PORT=5050

# Debug mode (true/false)
DEBUG=false

# Gmail credentials (optional — for email responder module)
GMAIL_USER=
GMAIL_APP_PASSWORD=
